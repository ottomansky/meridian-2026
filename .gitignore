# Local dev artifacts — never commit
/node_modules

# Ignore the entire Next.js build tree EXCEPT the standalone bundle,
# which is the Keboola deploy artifact and must be in git so the
# container starts without a build step.
/.next/*
!/.next/standalone

out
build
dist
.env*
!.env.example
!.env.local.example
.DS_Store
*.log
.vercel
next-env.d.ts
.turbo
tsconfig.tsbuildinfo
