# Local dev artifacts — never commit
/node_modules

# Ignore the entire Next.js build tree EXCEPT the standalone bundle,
# which is the Keboola deploy artifact and must be in git so the
# container starts without a build step.
/.next/*
!/.next/standalone

# Anchor these to the project root — without the leading slash they
# match nested dirs (e.g. node_modules/next/dist/) and silently shred
# the committed standalone bundle.
/out
/build
/dist
.env*
!.env.example
!.env.local.example
.DS_Store
*.log
.vercel
next-env.d.ts
.turbo
tsconfig.tsbuildinfo
